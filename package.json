{
  "name": "goodvibes-app",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "description": "GoodVibes desktop app — the unified GUI for the GoodVibes ecosystem (tui + agent feature set) on Bun + Electrobun.",
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.10"
  },
  "scripts": {
    "build": "bunx electrobun build",
    "dev": "bun run build && bun run launch",
    "launch": "bun scripts/launch.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check:boundaries": "bun scripts/check-boundaries.ts",
    "generate:routes": "bun scripts/generate-operator-routes.ts",
    "generate:presentation": "bun scripts/generate-presentation-tokens.ts",
    "generate": "bun run generate:routes && bun run generate:presentation",
    "generate:check": "bun scripts/generate-operator-routes.ts --check && bun scripts/generate-presentation-tokens.ts --check",
    "verify": "bun run typecheck && bun run check:boundaries && bun run generate:check && bun test"
  },
  "dependencies": {
    "@pellux/goodvibes-sdk": "1.11.2",
    "@pellux/goodvibes-tui": "1.19.3",
    "@tanstack/react-query": "^5.62.0",
    "electrobun": "1.18.1",
    "highlight.js": "^11.11.0",
    "lucide-react": "^0.525.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.0.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.185.0",
    "typescript": "^5.9.0"
  },
  "trustedDependencies": [
    "@pellux/goodvibes-sdk",
    "@pellux/goodvibes-tui",
    "electrobun"
  ]
}
